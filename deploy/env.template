# Koho Decks production env template.
#
# Rendered at deploy time by envsubst (.github/workflows/deploy.yml) with
# values pulled from the GitHub Actions `production` environment. Only
# ${VAR} placeholders are substituted; literal shell syntax would also
# expand, so don't introduce any.
#
# The rendered file lands at /home/decks/app/.env and is picked up by
# docker compose's default env_file behaviour.

# ── NextAuth / Google SSO (server-enforced @koho.ai domain) ────────────
AUTH_SECRET=${AUTH_SECRET}
AUTH_URL=https://decks.koho.ai
AUTH_GOOGLE_ID=${AUTH_GOOGLE_ID}
AUTH_GOOGLE_SECRET=${AUTH_GOOGLE_SECRET}

# ── Postgres (container-internal) ──────────────────────────────────────
POSTGRES_USER=koho
POSTGRES_PASSWORD=${POSTGRES_PASSWORD}
POSTGRES_DB=koho_decks
DATABASE_URL=postgresql://koho:${POSTGRES_PASSWORD}@postgres:5432/koho_decks

# ── App ───────────────────────────────────────────────────────────────
HOST_PORT=8094
APP_BASE_URL=https://decks.koho.ai
MIGRATE_DATABASE_ON_STARTUP=true
DISABLE_ANONYMOUS_TRACKING=true
CAN_CHANGE_KEYS=false
# koho-dev has no GPU and uses cloud LLM providers — skip the 13 GB
# ollama + CUDA install in the Dockerfile and the `ollama serve` spawn
# in start.js. See docker-compose.prod.yml and README's "Optional build
# flags" section.
INCLUDE_OLLAMA=false
# Shared between Next.js export routes and FastAPI's AuthMiddleware so the
# sessionless Puppeteer that renders /pdf-maker can still fetch deck data.
# Generate with `openssl rand -hex 32`.
INTERNAL_RENDER_TOKEN=${INTERNAL_RENDER_TOKEN}
# Disabled until we wire up a provider (Pexels/Gemini/DALL-E + key). The
# FastAPI startup lifespan raises "IMAGE_PROVIDER must be provided" if an
# image provider isn't configured, so this escape hatch is required even
# when the app is otherwise happy to run without it.
DISABLE_IMAGE_GENERATION=true

# ── LLM providers ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=${ANTHROPIC_API_KEY}
ANTHROPIC_MODEL=claude-opus-4-7
ANTHROPIC_MAX_TOKENS=8192

# Optional — left empty unless the corresponding GHA secret is set.
LLM=anthropic
OPENAI_API_KEY=${OPENAI_API_KEY}
OPENAI_MODEL=
GOOGLE_API_KEY=${GOOGLE_API_KEY}
GOOGLE_MODEL=
OLLAMA_URL=
OLLAMA_MODEL=
CUSTOM_LLM_URL=
CUSTOM_LLM_API_KEY=
CUSTOM_MODEL=
CODEX_MODEL=
PEXELS_API_KEY=${PEXELS_API_KEY}

# Feature flags
EXTENDED_REASONING=
TOOL_CALLS=
DISABLE_THINKING=
WEB_GROUNDING=

# Image generation backends (unused in prod, left for parity with compose)
COMFYUI_URL=
COMFYUI_WORKFLOW=
OPEN_WEBUI_IMAGE_URL=
OPEN_WEBUI_IMAGE_API_KEY=

# ── Gmail SMTP (optional, Phase 4d invitation emails) ─────────────────
SMTP_HOST=${SMTP_HOST}
SMTP_PORT=${SMTP_PORT}
SMTP_USER=${SMTP_USER}
SMTP_PASSWORD=${SMTP_PASSWORD}
SMTP_FROM=${SMTP_FROM}
