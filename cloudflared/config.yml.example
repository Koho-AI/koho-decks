# Cloudflare Tunnel config for Koho Decks (Phase 6).
#
# Setup once:
#   brew install cloudflared
#   cloudflared tunnel login                # opens browser to auth
#   cloudflared tunnel create koho-decks    # creates tunnel + cert
#   # Note the UUID printed; substitute it below.
#   cloudflared tunnel route dns koho-decks decks.koho.ai
#
# Then copy this file to ~/.cloudflared/config.yml and fill in the UUID:
#   cp cloudflared/config.yml.example ~/.cloudflared/config.yml
#   $EDITOR ~/.cloudflared/config.yml
#
# Run as a launchd service:
#   sudo cloudflared service install
#   sudo launchctl start com.cloudflare.cloudflared

tunnel: REPLACE_WITH_TUNNEL_UUID
credentials-file: /Users/REPLACE_USER/.cloudflared/REPLACE_WITH_TUNNEL_UUID.json

# Origin connections — keep timeouts loose; deck generation can take
# minutes when the LLM is slow.
originRequest:
  connectTimeout: 30s
  tlsTimeout: 30s
  tcpKeepAlive: 30s
  noHappyEyeballs: false
  keepAliveConnections: 100
  keepAliveTimeout: 90s
  httpHostHeader: localhost
  disableChunkedEncoding: false

ingress:
  # Editor (auth-gated): protected by Cloudflare Access in the dashboard.
  # The Access policy should allow only @koho.ai Workspace identities.
  - hostname: decks.koho.ai
    service: http://localhost:5000

  # Catch-all so cloudflared has a default rule.
  - service: http_status:404
